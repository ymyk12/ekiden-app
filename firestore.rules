rules_version = '2';

// ベースラインルール（匿名認証は維持する方針）
//
// 守れること:
//  - 未認証（REST直叩き等）の読み書きを全て遮断する
//  - アプリのデータ領域（artifacts/.../public/data）以外を全て遮断する
//
// 守れないこと（既知の限界・将来の課題）:
//  - 匿名サインインさえすれば誰でも読み書きできる点は変わらない
//  - Firestoreルールはフィールド単位の読み取り制限ができないため、
//    runners ドキュメント内の pin はクライアントに渡る。
//    本格的に守るには pin を別コレクションに分離し、照合を
//    Cloud Functions（callable）に移すデータ移行が必要。
service cloud.firestore {
  match /databases/{database}/documents {

    // このアプリのデータ領域: 認証済み（匿名含む）ユーザーのみ許可
    match /artifacts/kswc-ekidenteam-distancerecords/public/data/{collection}/{docId} {
      allow read, write: if request.auth != null;
    }

    // 通知キューはCloud Functions（Admin SDK）専用。クライアントからは触れない
    // （Admin SDKはルールを通らないため、ここで拒否してもFunctionsは動く）
    match /notification_queue/{docId} {
      allow read, write: if false;
    }

    // 上記以外は全拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
